# auditd Custom Rules
# Project: Linux Hardening + CIS Benchmark
# Apply: sudo cp hardening.rules /etc/audit/rules.d/ && sudo augenrules --load

# ── Identity — Critical File Monitoring ──────────────────────
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

# ── SSH Config Monitoring ─────────────────────────────────────
-w /etc/ssh/sshd_config -p wa -k sshd_config

# ── Privilege Escalation ──────────────────────────────────────
-a always,exit -F arch=b64 -S setuid -k privilege_escalation
-a always,exit -F arch=b64 -S setgid -k privilege_escalation
-w /bin/su -p x -k privilege_escalation
-w /usr/bin/sudo -p x -k privilege_escalation
-w /usr/bin/sudoedit -p x -k privilege_escalation

# ── Session Tracking (Login / Logout) ─────────────────────────
-w /var/run/utmp -p wa -k session
-w /var/log/wtmp -p wa -k session
-w /var/log/btmp -p wa -k session
-w /var/log/lastlog -p wa -k session

# ── System Administration Actions ─────────────────────────────
-w /sbin/insmod -p x -k modules
-w /sbin/rmmod -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module -k modules

# ── Network Configuration Changes ─────────────────────────────
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k network_changes
-w /etc/hosts -p wa -k network_changes
-w /etc/network/ -p wa -k network_changes

# ── Crontab Monitoring ────────────────────────────────────────
-w /etc/cron.d/ -p wa -k cron
-w /etc/crontab -p wa -k cron
-w /var/spool/cron/ -p wa -k cron

# ── Make rules immutable (requires reboot to change) ──────────
# Uncomment in production after rules are finalized:
# -e 2
