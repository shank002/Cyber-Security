#!/bin/bash
# =============================================================================
# backup_monitor.sh — Generated by Ansible on {{ inventory_hostname }}
# Managed by: ansible-playbook site.yml
# =============================================================================

set -euo pipefail

BACKUP_ROOT="{{ backup_root }}"
FULL_BACKUP_DIR="{{ backup_full_dir }}"
INCR_BACKUP_DIR="{{ backup_incr_dir }}"
LOG_DIR="{{ backup_log_dir }}"
ALERT_EMAIL="{{ backup_alert_email }}"
WARN_DISK_PERCENT={{ backup_warn_disk_percent }}
WARN_FULL_AGE_DAYS=8
WARN_INCR_AGE_HOURS=26

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; NC='\033[0m'; BOLD='\033[1m'
ISSUES=()

section() { echo -e "\n${BOLD}${BLUE}=== $* ===${NC}"; }
ok()      { echo -e "  ${GREEN}[OK]${NC}   $*"; }
warn()    { echo -e "  ${YELLOW}[WARN]${NC} $*"; ISSUES+=("WARN: $*"); }
fail()    { echo -e "  ${RED}[FAIL]${NC} $*"; ISSUES+=("FAIL: $*"); }
info()    { echo -e "  ${BLUE}[INFO]${NC} $*"; }

check_full() {
    section "Full Backup"
    local latest
    latest=$(find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??" 2>/dev/null | sort -r | head -n 1)
    [[ -z "${latest}" ]] && { fail "No full backup found"; return; }
    local age=$(( ( $(date +%s) - $(date -d "$(basename "$latest")" +%s) ) / 86400 ))
    info "Latest: $(basename "$latest") | Age: ${age} day(s) | Size: $(du -sh "$latest" | cut -f1)"
    [[ ${age} -gt ${WARN_FULL_AGE_DAYS} ]] && warn "Full backup is ${age} days old" || ok "Full backup current"
}

check_incr() {
    section "Incremental Backup"
    local latest
    latest=$(find "${INCR_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??_*" 2>/dev/null | sort -r | head -n 1)
    [[ -z "${latest}" ]] && { warn "No incremental backups found"; return; }
    local age=$(( ( $(date +%s) - $(stat -c %Y "$latest") ) / 3600 ))
    info "Latest: $(basename "$latest") | Age: ${age}h | Size: $(du -sh "$latest" | cut -f1)"
    [[ ${age} -gt ${WARN_INCR_AGE_HOURS} ]] && warn "Incremental is ${age}h old" || ok "Incremental current"
}

check_disk() {
    section "Disk Space"
    local pct
    pct=$(df -k "${BACKUP_ROOT}" | awk 'NR==2{print $5}' | tr -d '%')
    local avail
    avail=$(df -h "${BACKUP_ROOT}" | awk 'NR==2{print $4}')
    info "Usage: ${pct}% | Free: ${avail}"
    [[ ${pct} -ge ${WARN_DISK_PERCENT} ]] && warn "Disk at ${pct}%" || ok "Disk usage acceptable"
}

check_logs() {
    section "Log Errors"
    for log in "${LOG_DIR}/full_backup.log" "${LOG_DIR}/incremental_backup.log"; do
        [[ ! -f "${log}" ]] && { warn "Missing log: $(basename $log)"; continue; }
        local errs
        errs=$(grep -c '\[ERROR\]' "${log}" 2>/dev/null || echo 0)
        [[ ${errs} -gt 0 ]] && warn "$(basename $log): ${errs} error(s)" || ok "$(basename $log): clean"
    done
}

echo -e "${BOLD}\n===================================="
echo " Backup Monitor — {{ inventory_hostname }}"
echo " $(date '+%Y-%m-%d %H:%M:%S')"
echo -e "====================================\n${NC}"

check_full
check_incr
check_disk
check_logs

section "Summary"
if [[ ${#ISSUES[@]} -eq 0 ]]; then
    echo -e "  ${GREEN}${BOLD}All checks passed.${NC}"
else
    echo -e "  ${YELLOW}${BOLD}${#ISSUES[@]} issue(s):${NC}"
    for i in "${ISSUES[@]}"; do echo -e "    ${YELLOW}• ${i}${NC}"; done
    if [[ -n "${ALERT_EMAIL}" ]] && command -v mailx &>/dev/null; then
        printf "%s\n" "${ISSUES[@]}" | mailx -s "[BACKUP ALERT] {{ inventory_hostname }}" "${ALERT_EMAIL}"
    fi
fi
echo ""
