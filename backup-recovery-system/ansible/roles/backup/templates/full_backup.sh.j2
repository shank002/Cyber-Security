#!/bin/bash
# =============================================================================
# full_backup.sh — Generated by Ansible on {{ inventory_hostname }}
# Managed by: ansible-playbook site.yml
# Do NOT edit this file directly — edit the template and re-run the playbook.
# =============================================================================

set -euo pipefail

# --- Configuration (injected by Ansible) ---
BACKUP_ROOT="{{ backup_root }}"
FULL_BACKUP_DIR="{{ backup_full_dir }}"
LOG_DIR="{{ backup_log_dir }}"
LOG_FILE="${LOG_DIR}/full_backup.log"
LOCK_FILE="/var/run/full_backup.lock"
RETENTION_WEEKS={{ backup_retention_weeks }}
ALERT_EMAIL="{{ backup_alert_email }}"

SOURCE_DIRS=(
{% for dir in backup_source_dirs %}
    "{{ dir }}"
{% endfor %}
)

EXCLUDES=(
{% for excl in backup_excludes %}
    "--exclude={{ excl }}"
{% endfor %}
)

# --- Functions ---
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$1] ${@:2}" | tee -a "${LOG_FILE}"; }
info()    { log "INFO " "$@"; }
success() { log "OK   " "$@"; }
warn()    { log "WARN " "$@"; }
error()   { log "ERROR" "$@"; }

send_alert() {
    if [[ -n "${ALERT_EMAIL}" ]] && command -v mailx &>/dev/null; then
        echo "$2" | mailx -s "$1" "${ALERT_EMAIL}"
    fi
}

check_root() {
    [[ "${EUID}" -ne 0 ]] && { echo "Must run as root."; exit 1; }
}

acquire_lock() {
    if [[ -f "${LOCK_FILE}" ]]; then
        pid=$(cat "${LOCK_FILE}")
        kill -0 "${pid}" 2>/dev/null && { error "Already running (PID: ${pid})."; exit 1; }
        rm -f "${LOCK_FILE}"
    fi
    echo $$ > "${LOCK_FILE}"
}

rotate_old_backups() {
    local count
    count=$(find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??" | wc -l)
    if [[ "${count}" -gt "${RETENTION_WEEKS}" ]]; then
        find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??" \
            | sort | head -n $(( count - RETENTION_WEEKS )) \
            | xargs rm -rf
    fi
}

# --- Main ---
TIMESTAMP=$(date '+%Y-%m-%d')
TARGET_DIR="${FULL_BACKUP_DIR}/${TIMESTAMP}"
START_TIME=$(date +%s)

check_root
mkdir -p "${LOG_DIR}" "${FULL_BACKUP_DIR}"
acquire_lock
trap 'rm -f "${LOCK_FILE}"' EXIT

info "Starting FULL backup on $(hostname) (managed by Ansible)"
info "Target: ${TARGET_DIR}"

[[ -d "${TARGET_DIR}" ]] && { warn "Today's full backup already exists. Skipping."; exit 0; }
mkdir -p "${TARGET_DIR}"

FAILED=()
for src in "${SOURCE_DIRS[@]}"; do
    [[ ! -d "${src}" ]] && { warn "Skipping missing dir: ${src}"; continue; }
    info "Backing up: ${src}"
    if rsync -aAXHz --delete --stats "${EXCLUDES[@]}" "${src}" "${TARGET_DIR}/" >> "${LOG_FILE}" 2>&1; then
        success "Done: ${src}"
    else
        error "Failed: ${src}"; FAILED+=("${src}")
    fi
done

cat > "${TARGET_DIR}/.backup_meta" <<EOF
backup_type=full
hostname=$(hostname)
ansible_managed=true
timestamp=${TIMESTAMP}
EOF

rotate_old_backups

END_TIME=$(date +%s)
DURATION=$(( END_TIME - START_TIME ))

if [[ ${#FAILED[@]} -gt 0 ]]; then
    error "Completed WITH ERRORS in ${DURATION}s. Failed: ${FAILED[*]}"
    send_alert "[BACKUP WARNING] $(hostname)" "Failed: ${FAILED[*]}"
    exit 1
else
    success "COMPLETED SUCCESSFULLY in ${DURATION}s."
fi
