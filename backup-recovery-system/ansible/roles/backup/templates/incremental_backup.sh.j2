#!/bin/bash
# =============================================================================
# incremental_backup.sh — Generated by Ansible on {{ inventory_hostname }}
# Managed by: ansible-playbook site.yml
# Do NOT edit this file directly — edit the template and re-run the playbook.
# =============================================================================

set -euo pipefail

BACKUP_ROOT="{{ backup_root }}"
FULL_BACKUP_DIR="{{ backup_full_dir }}"
INCR_BACKUP_DIR="{{ backup_incr_dir }}"
LOG_DIR="{{ backup_log_dir }}"
LOG_FILE="${LOG_DIR}/incremental_backup.log"
LOCK_FILE="/var/run/incremental_backup.lock"
RETENTION_DAYS={{ backup_retention_days }}
ALERT_EMAIL="{{ backup_alert_email }}"

SOURCE_DIRS=(
{% for dir in backup_source_dirs %}
    "{{ dir }}"
{% endfor %}
)

EXCLUDES=(
{% for excl in backup_excludes %}
    "--exclude={{ excl }}"
{% endfor %}
)

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$1] ${@:2}" | tee -a "${LOG_FILE}"; }
info()    { log "INFO " "$@"; }
success() { log "OK   " "$@"; }
warn()    { log "WARN " "$@"; }
error()   { log "ERROR" "$@"; }

send_alert() {
    if [[ -n "${ALERT_EMAIL}" ]] && command -v mailx &>/dev/null; then
        echo "$2" | mailx -s "$1" "${ALERT_EMAIL}"
    fi
}

TIMESTAMP=$(date '+%Y-%m-%d_%H%M%S')
TARGET_DIR="${INCR_BACKUP_DIR}/${TIMESTAMP}"
START_TIME=$(date +%s)

[[ "${EUID}" -ne 0 ]] && { echo "Must run as root."; exit 1; }

if [[ -f "/var/run/incremental_backup.lock" ]]; then
    pid=$(cat /var/run/incremental_backup.lock)
    kill -0 "${pid}" 2>/dev/null && { error "Already running."; exit 1; }
fi
echo $$ > /var/run/incremental_backup.lock
trap 'rm -f /var/run/incremental_backup.lock' EXIT

mkdir -p "${LOG_DIR}" "${INCR_BACKUP_DIR}" "${TARGET_DIR}"

LINK_DEST=""
LATEST_INCR=$(find "${INCR_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??_*" | sort -r | head -n 1)
LATEST_FULL=$(find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??" | sort -r | head -n 1)

if [[ -n "${LATEST_INCR}" ]]; then
    LINK_DEST="${LATEST_INCR}"
elif [[ -n "${LATEST_FULL}" ]]; then
    LINK_DEST="${LATEST_FULL}"
else
    error "No full backup found. Run full_backup.sh first."
    send_alert "[BACKUP FAILED] $(hostname)" "No full backup found."
    exit 1
fi

info "Starting INCREMENTAL backup on $(hostname) (managed by Ansible)"
info "Link-dest: ${LINK_DEST}"

FAILED=()
for src in "${SOURCE_DIRS[@]}"; do
    [[ ! -d "${src}" ]] && { warn "Skipping: ${src}"; continue; }
    info "Backing up: ${src}"
    if rsync -aAXHz --delete --stats "${EXCLUDES[@]}" \
        --link-dest="${LINK_DEST}/" "${src}" "${TARGET_DIR}/" >> "${LOG_FILE}" 2>&1; then
        success "Done: ${src}"
    else
        error "Failed: ${src}"; FAILED+=("${src}")
    fi
done

cat > "${TARGET_DIR}/.backup_meta" <<EOF
backup_type=incremental
hostname=$(hostname)
ansible_managed=true
timestamp=${TIMESTAMP}
link_dest=${LINK_DEST}
EOF

find "${INCR_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??_*" \
    -mtime +${RETENTION_DAYS} -exec rm -rf {} +

END_TIME=$(date +%s)
DURATION=$(( END_TIME - START_TIME ))

if [[ ${#FAILED[@]} -gt 0 ]]; then
    error "Completed WITH ERRORS in ${DURATION}s. Failed: ${FAILED[*]}"
    send_alert "[BACKUP WARNING] $(hostname)" "Failed: ${FAILED[*]}"
    exit 1
else
    success "COMPLETED SUCCESSFULLY in ${DURATION}s."
fi
