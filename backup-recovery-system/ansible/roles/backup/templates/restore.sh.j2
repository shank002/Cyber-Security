#!/bin/bash
# =============================================================================
# restore.sh — Generated by Ansible on {{ inventory_hostname }}
# Managed by: ansible-playbook site.yml
# =============================================================================
# Usage:
#   sudo ./restore.sh --list
#   sudo ./restore.sh --date 2025-03-20 --dry-run
#   sudo ./restore.sh --date 2025-03-20
#   sudo ./restore.sh --date 2025-03-20 --source /etc --target /mnt/staging
# =============================================================================

set -euo pipefail

BACKUP_ROOT="{{ backup_root }}"
FULL_BACKUP_DIR="{{ backup_full_dir }}"
INCR_BACKUP_DIR="{{ backup_incr_dir }}"
LOG_FILE="{{ backup_log_dir }}/restore.log"

RESTORE_DATE=""
SOURCE_PATH=""
TARGET_PATH="/"
DRY_RUN=false
LIST_MODE=false

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$1] ${@:2}" | tee -a "${LOG_FILE}"; }
info()    { log "INFO " "$@"; }
success() { log "OK   " "$@"; }
error()   { log "ERROR" "$@"; }

[[ "${EUID}" -ne 0 ]] && { echo "Must run as root."; exit 1; }
mkdir -p "{{ backup_log_dir }}"

list_backups() {
    echo ""; echo "=== Full Backups ==="
    find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??" 2>/dev/null | sort | while read -r d; do
        printf "  %-20s  %s\n" "$(basename "$d")" "$(du -sh "$d" 2>/dev/null | cut -f1)"
    done
    echo ""; echo "=== Incremental Backups ==="
    find "${INCR_BACKUP_DIR}" -maxdepth 1 -type d -name "????-??-??_*" 2>/dev/null | sort | while read -r d; do
        printf "  %-28s  %s\n" "$(basename "$d")" "$(du -sh "$d" 2>/dev/null | cut -f1)"
    done
    echo ""
}

find_backup() {
    local d
    d=$(find "${INCR_BACKUP_DIR}" -maxdepth 1 -type d -name "${1}*" 2>/dev/null | sort -r | head -n 1)
    [[ -z "$d" ]] && d=$(find "${FULL_BACKUP_DIR}" -maxdepth 1 -type d -name "${1}*" 2>/dev/null | sort -r | head -n 1)
    echo "$d"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list)    LIST_MODE=true; shift ;;
        --date)    RESTORE_DATE="$2"; shift 2 ;;
        --source)  SOURCE_PATH="$2"; shift 2 ;;
        --target)  TARGET_PATH="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        *) echo "Unknown: $1"; exit 1 ;;
    esac
done

${LIST_MODE} && { list_backups; exit 0; }
[[ -z "${RESTORE_DATE}" ]] && { echo "Specify --date. Use --list to see options."; exit 1; }

BACKUP_DIR=$(find_backup "${RESTORE_DATE}")
[[ -z "${BACKUP_DIR}" ]] && { error "No backup found for: ${RESTORE_DATE}"; exit 1; }

info "Restore from: ${BACKUP_DIR}"
${DRY_RUN} && info "DRY RUN — no changes will be made"

RSYNC_OPTS=(-aAXHz --delete --stats)
${DRY_RUN} && RSYNC_OPTS+=(--dry-run)

if [[ -n "${SOURCE_PATH}" ]]; then
    REL="${SOURCE_PATH#/}"
    SRC="${BACKUP_DIR}/${REL}/"
    [[ ! -d "${SRC}" ]] && { error "Not found in backup: ${SRC}"; exit 1; }
    mkdir -p "${TARGET_PATH}/${REL}"
    rsync "${RSYNC_OPTS[@]}" "${SRC}" "${TARGET_PATH}/${REL}/" | tee -a "${LOG_FILE}"
else
    for subdir in "${BACKUP_DIR}"/*/; do
        [[ -d "${subdir}" ]] || continue
        n=$(basename "${subdir}")
        mkdir -p "${TARGET_PATH}/${n}"
        rsync "${RSYNC_OPTS[@]}" "${subdir}" "${TARGET_PATH}/${n}/" >> "${LOG_FILE}" 2>&1
        success "Restored: /${n}"
    done
fi

${DRY_RUN} && success "Dry run complete." || success "Restore complete."
