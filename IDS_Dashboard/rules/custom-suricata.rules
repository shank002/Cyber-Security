# Custom Suricata Detection Rules
# File: /etc/suricata/rules/custom.rules
# Description: Custom IDS rules for home lab attack detection
# Author: [Your Name]
# Last Updated: 2026

# ─────────────────────────────────────────────
# RULE 1 — SSH Brute Force Detection
# Triggers when a single source IP makes 5+ TCP connections
# to port 22 (SSH) within 10 seconds
# ─────────────────────────────────────────────
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; threshold:type threshold, track by_src, count 5, seconds 10; sid:1000002; rev:1;)

# ─────────────────────────────────────────────
# RULE 2 — Nmap Port Scan Detection
# Triggers when a single source IP sends 20+ TCP SYN packets
# within 3 seconds (signature of a SYN scan)
# ─────────────────────────────────────────────
alert tcp any any -> $HOME_NET any (msg:"Nmap Port Scan Detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 3; sid:1000003; rev:1;)

# ─────────────────────────────────────────────
# RULE 3 — ICMP Ping Flood Detection
# Triggers when a single source IP sends 10+ ICMP packets
# within 2 seconds (signature of ping -f flood)
# ─────────────────────────────────────────────
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Flood Detected"; threshold:type threshold, track by_src, count 10, seconds 2; sid:1000004; rev:1;)

# ─────────────────────────────────────────────
# RULE 4 — Any ICMP Ping (for basic testing)
# No threshold — fires on every single ICMP ping
# Use only for initial rule validation testing, then disable
# ─────────────────────────────────────────────
# alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Detected - Test Rule"; sid:1000005; rev:1;)
